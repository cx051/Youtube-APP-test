{
  "name": "youtube",
  "version": "2.0.1",
  "description": "YouTube app with ad blocker and performance optimizations",
  "main": "main.js",
  "author": "cx051",
  "homepage": "https://github.com/cx051/youtube-app",
  "license": "ISC",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --linux --win"
  },
  "dependencies": {
    "@cyriacbr/react-split-text": "^1.0.0",
    "@ghostery/adblocker-electron": "^2.14.1",
    "cross-fetch": "^4.1.0",
    "framer-motion": "^12.36.0",
    "punycode": "^2.3.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.cx051.youtubeapp",
    "productName": "YouTubeApp",
    "files": [
      "index.html",
      "splash.html",
      "main.js",
      "preload.js",
      "adblocker.js",
      "settings-manager.js",
      "scripts/**/*",
      "components/**/*",
      "assets/**/*",
      "node_modules/@ghostery/adblocker-electron/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "linux": {
      "target": [
        "deb"
      ],
      "icon": "assets/YouTube (original).png",
      "category": "Video",
      "maintainer": "cx051"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/YouTube.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
